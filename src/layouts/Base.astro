---
import "../styles/globals.css";
import Masthead from "../components/Masthead.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "conilab — a notebook by @coni",
  description = "Long-form bilingual notes by Coni. Re-learning the world with AI, one ≥3000-word piece at a time.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="conilab" href="/articles/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Pre-paint lang state: avoid flash of bilingual content before lang-switcher script runs.
         Default = 'en' if no localStorage. Honors prior choice. -->
    <script is:inline>
      try {
        var saved = localStorage.getItem("conilab-lang");
        var mode = saved || "en";
        if (mode === "zh") document.documentElement.classList.add("show-zh");
        else if (mode === "en") document.documentElement.classList.add("show-en");
      } catch (_) {}
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Masthead />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
