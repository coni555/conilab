---
import Base from "../layouts/Base.astro";
import Kicker from "../components/Kicker.astro";
import CoinGlyph from "../components/CoinGlyph.astro";

const sites = [
  {
    name: "自推站",
    name_en: "Oshi Shrine",
    url: "https://zitui.conilab.cn",
    desc_zh: "展示我喜欢的动漫角色。",
    desc_en: "Characters that stuck with me.",
    tag: "oshi",
  },
];
---

<Base
  title="Interests — conilab"
  description="Sites and projects by @coni — things I care about outside of writing."
>
  <section class="interests">
    <div class="wrap">
      <header class="interests-head">
        <Kicker text="interests · 兴趣" accent />
        <h1 class="interests-title">
          <span class="cjk" lang="zh">我在别处做的事</span>
        </h1>
        <p class="interests-lede" data-lang="en">
          Other corners of the internet I maintain.
        </p>
      </header>

      <ul class="site-list">
        {sites.map((s) => (
          <li class="site-entry">
            <a
              href={s.url}
              target={s.url.startsWith("/") ? undefined : "_blank"}
              rel={s.url.startsWith("/") ? undefined : "noopener"}
              class="site-link"
            >
              <div class="site-meta">
                <span class="site-tag">{s.tag}</span>
              </div>
              <h2 class="site-name">
                <span class="site-name-zh cjk" lang="zh">{s.name}</span>
                <span class="site-name-en">{s.name_en}</span>
              </h2>
              <p class="site-desc cjk" data-lang="zh" lang="zh">{s.desc_zh}</p>
              <p class="site-desc" data-lang="en">{s.desc_en}</p>
              <span class="site-url-display" aria-hidden="true">
                <CoinGlyph size="0.9em" variant="dot" />
                {s.url === "#" ? "coming soon" : s.url.replace(/^https?:\/\//, "")}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
  .interests {
    padding: var(--sp-44) 0 var(--sp-96);
  }

  .interests-head {
    border-bottom: var(--sp-hairline) solid var(--rule);
    padding-bottom: var(--sp-32);
    margin-bottom: var(--sp-44);
  }
  .interests-title {
    font-family: var(--cjk-serif);
    font-size: clamp(var(--fs-4xl), 4vw, var(--fs-7xl));
    font-weight: var(--fw-medium);
    line-height: var(--lh-snug);
    margin: var(--sp-12) 0 var(--sp-14);
    color: var(--ink);
  }
  .interests-lede {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-lg);
    color: var(--ink-3);
    font-weight: var(--fw-light);
    margin: 0;
  }

  .site-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-22);
  }

  .site-entry {
    border: var(--sp-hairline) solid var(--rule);
    border-radius: var(--rad-4);
    transition: border-color var(--dur-quick), background var(--dur-quick);
  }
  .site-entry:hover {
    border-color: var(--accent-back);
    background: color-mix(in oklch, var(--accent-back) 3%, var(--paper));
  }

  .site-link {
    display: block;
    padding: var(--sp-28) var(--sp-32);
  }

  .site-meta {
    margin-bottom: var(--sp-14);
  }
  .site-tag {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-back);
    border: var(--sp-hairline) solid var(--accent-back);
    padding: var(--sp-2) var(--sp-8);
    border-radius: var(--rad-pill);
  }

  .site-name {
    font-family: var(--serif);
    font-weight: var(--fw-medium);
    margin: 0 0 var(--sp-10);
    display: flex;
    align-items: baseline;
    gap: var(--sp-12);
    flex-wrap: wrap;
  }
  .site-name-zh {
    font-family: var(--cjk-serif);
    font-size: var(--fs-3xl);
    color: var(--ink);
  }
  .site-name-en {
    font-family: var(--serif);
    font-size: var(--fs-lg);
    font-style: italic;
    font-weight: var(--fw-light);
    color: var(--accent-back-ink);
  }

  .site-desc {
    font-family: var(--sans);
    font-size: var(--fs-md);
    color: var(--ink-2);
    line-height: var(--lh-relaxed);
    margin: 0 0 var(--sp-4);
  }
  .site-desc[data-lang="en"] {
    font-style: italic;
    color: var(--ink-3);
    font-size: var(--fs-sm);
  }

  .site-url-display {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-6);
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin-top: var(--sp-14);
  }

  @media (max-width: 720px) {
    .site-link { padding: var(--sp-22) var(--sp-18); }
  }
</style>
