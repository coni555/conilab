---
import Base from "../layouts/Base.astro";
import Kicker from "../components/Kicker.astro";

interface Book {
  title: string;
  title_en?: string;
  author: string;
  review: string;
  cover?: string;
  year?: number;
}

type Tier = {
  label: string;
  label_en: string;
  books: Book[];
};

const tiers: Tier[] = [
  {
    label: "夯",
    label_en: "S",
    books: [
      { title: "长大就是边走边选", author: "李尚龙", review: "开启了我阅读的兴趣", cover: "/covers/growing-up-choosing.jpg", year: 2024 },
      { title: "把时间当作朋友", author: "李笑来", review: "改变了我对「学习」这件事的理解", cover: "/covers/time-as-friend.jpg", year: 2024 },
      { title: "纳瓦尔宝典", title_en: "The Almanack of Naval Ravikant", author: "Eric Jorgenson", review: "财富和幸福的操作系统", cover: "/covers/naval-almanack.jpg", year: 2024 },
      { title: "认知觉醒", author: "周岭", review: "正如书名，开启认知改变的原动力", cover: "/covers/cognitive-awakening.jpg", year: 2025 },
      { title: "认知驱动", author: "周岭", review: "觉醒之后的下一步，从认知到行动的闭环", cover: "/covers/cognitive-drive.jpg", year: 2025 },
      { title: "福格行为模型", title_en: "Tiny Habits", author: "BJ Fogg", review: "从底层破解执行力，B=MAP 拆解一切行动", cover: "/covers/tiny-habits.jpg", year: 2025 },
      { title: "Just Keep Buying", author: "Nick Maggiulli", review: "丰富了我的理财观，坚定持续买入的信念", cover: "/covers/just-keep-buying.jpg", year: 2025 },
      { title: "The Wealth Ladder", author: "Nick Maggiulli", review: "构建完整的财富增长路径，和 JKB 互补", cover: "/covers/wealth-ladder.jpg", year: 2025 },
      { title: "奥尔特曼传", author: "赵鑫", review: "了解世界 AI 发展历程的一本好书", cover: "/covers/altman-bio.jpg", year: 2025 },
      { title: "专注的真相", author: "李笑来", review: "注意力才是你最贵的资产，比时间还贵", cover: "/covers/truth-of-focus.jpg", year: 2025 },
      { title: "财富的真相", author: "李笑来", review: "把赚钱这件事拆到你能执行的粒度", cover: "/covers/truth-of-wealth.jpg", year: 2025 },
      { title: "Thinking in Bets", author: "Annie Duke", review: "用概率思维做决定，增强面对不确定性的信心", cover: "/covers/thinking-in-bets.jpg", year: 2025 },
    ],
  },
  {
    label: "顶级",
    label_en: "A",
    books: [
      { title: "定投改变命运", author: "李笑来", review: "简单到不需要解释，难在你做不做", cover: "/covers/regular-investing.jpg", year: 2024 },
      { title: "穷查理宝典", title_en: "Poor Charlie's Almanack", author: "Peter D. Kaufman", review: "多元思维模型的活教材", cover: "/covers/poor-charlies-almanack.jpg", year: 2025 },
      { title: "我在100天内自学英文翻转人生", author: "张同完", review: "看完后才有了无字幕看《Notting Hill》的勇气", cover: "/covers/100-days-english.jpg", year: 2025 },
      { title: "深度工作", title_en: "Deep Work", author: "Cal Newport", review: "开拓了我对注意力的认知", cover: "/covers/deep-work.jpg", year: 2025 },
      { title: "底层逻辑", author: "刘润", review: "透过生活中的各种现象，带你看本质逻辑", cover: "/covers/underlying-logic.jpg", year: 2025 },
      { title: "人性博弈", author: "卫蓝", review: "思维认知的补充，理解人性中的博弈法则", cover: "/covers/human-nature-game.jpg", year: 2025 },
      { title: "内在的探索", title_en: "The Unfolding Now", author: "A.H. Almaas", review: "很哲学很不好理解，但「坑洞理论」值回票价", cover: "/covers/unfolding-now.jpg", year: 2025 },
      { title: "清晰思考", title_en: "Clear Thinking", author: "Shane Parrish", review: "四个默认值框架，实用的决策工具", cover: "/covers/clear-thinking.jpg", year: 2025 },
      { title: "让时间陪你慢慢变富", author: "李笑来", review: "更加坚定定投的信念", cover: "/covers/time-grow-rich.jpg", year: 2025 },
    ],
  },
  {
    label: "人上人",
    label_en: "B",
    books: [
      { title: "认知突围", author: "蔡垒磊", review: "和浪前的一些理念互补，拓宽认知边界", cover: "/covers/cognitive-breakthrough.jpg", year: 2025 },
      { title: "年轻人会用的AI写作", author: "李尚龙", review: "一些实用的 AI 使用建议", cover: "/covers/ai-writing-youth.jpg", year: 2025 },
      { title: "思考的真相", author: "李笑来", review: "李笑来真相系列收尾，思维层面的补全", cover: "/covers/truth-of-thinking.jpg", year: 2025 },
    ],
  },
  {
    label: "NPC",
    label_en: "C",
    books: [
      { title: "How to Make Your Brain Your Best Friend", author: "Deepak Chopra", review: "慰藉心灵的读物，当时需要这份温暖", cover: "/covers/brain-best-friend.jpg", year: 2025 },
    ],
  },
  {
    label: "拉完了",
    label_en: "D",
    books: [],
  },
];

const totalBooks = tiers.reduce((n, t) => n + t.books.length, 0);
---

<Base
  title="Books — conilab"
  description="从夯到拉的读书锐评。A brutally honest tier list of everything I've read."
>
  <section class="books">
    <div class="wrap">
      <header class="books-head">
        <Kicker text="books · 读过的书" accent />
        <h1 class="books-title">
          <span class="cjk" lang="zh">从夯到拉</span>
        </h1>
        <p class="books-lede" data-lang="en">
          A brutally honest tier list.
        </p>
        <p class="books-note-top cjk" lang="zh">
          只列出读过且记忆深刻的书，不是全部阅读记录。
        </p>
        <p class="books-count">{totalBooks} books ranked</p>
      </header>

      <div class="tier-list">
        {tiers.map((tier) => (
          <div class={`tier tier--${tier.label_en.toLowerCase()}`}>
            <div class="tier-label">
              <span class="tier-zh">{tier.label}</span>
              <span class="tier-en">{tier.label_en}</span>
            </div>
            <div class="tier-books">
              {tier.books.length > 0 ? (
                tier.books.map((book) => (
                  <div class="book-tile">
                    <div class="tile-cover-wrap">
                      {book.cover ? (
                        <img class="tile-cover" src={book.cover} alt={book.title} loading="lazy" />
                      ) : (
                        <div class="tile-fallback" aria-hidden="true">
                          <span>{book.title.charAt(0)}</span>
                        </div>
                      )}
                    </div>
                    <div class="tile-meta">
                      <span class="tile-title cjk" lang="zh">{book.title}</span>
                      {book.title_en && (
                        <span class="tile-title-en">{book.title_en}</span>
                      )}
                      <span class="tile-author">{book.author}</span>
                    </div>
                    <div class="tile-review-popup">
                      <p class="tile-review cjk" lang="zh">{book.review}</p>
                      {book.year && <span class="tile-year">{book.year}</span>}
                    </div>
                  </div>
                ))
              ) : (
                <div class="tier-empty">—</div>
              )}
            </div>
          </div>
        ))}
      </div>

      <footer class="books-foot">
        <p class="books-note cjk" lang="zh">
          纯主观锐评，不构成推荐。一本书在哪个档取决于它对<em>我</em>的影响，不是它的客观质量。
        </p>
        <p class="books-note" data-lang="en">
          Purely subjective. A book's tier reflects its impact on <em>me</em>, not its objective quality.
        </p>
      </footer>
    </div>
  </section>
</Base>

<style>
  .books {
    padding: var(--sp-44) 0 var(--sp-96);
  }

  /* ── HEAD ── */
  .books-head {
    margin-bottom: var(--sp-44);
    border-bottom: var(--sp-hairline) solid var(--rule);
    padding-bottom: var(--sp-32);
  }
  .books-title {
    font-family: var(--cjk-serif);
    font-size: clamp(var(--fs-5xl), 4vw, 52px);
    line-height: 1.1;
    color: var(--ink);
    font-weight: var(--fw-medium);
    margin: 0 0 var(--sp-8);
  }
  .books-lede {
    font-family: var(--serif);
    font-size: var(--fs-lg);
    font-style: italic;
    font-weight: var(--fw-light);
    color: var(--ink-3);
    margin: 0 0 var(--sp-12);
  }
  .books-note-top {
    font-family: var(--cjk-serif);
    font-size: var(--fs-sm);
    color: var(--ink-3);
    font-weight: var(--fw-light);
    margin: 0 0 var(--sp-12);
  }
  .books-count {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
  }

  /* ── TIER LIST ── */
  .tier-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tier {
    display: grid;
    grid-template-columns: 72px 1fr;
    min-height: 72px;
    border-bottom: var(--sp-hairline) solid var(--rule);
  }
  .tier:first-child {
    border-top: var(--sp-hairline) solid var(--rule);
  }

  /* ── TIER LABELS (OKLCH warm→cool) ── */
  .tier-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    border-right: var(--sp-hairline) solid var(--rule);
    padding: var(--sp-12) var(--sp-8);
  }
  .tier-zh {
    font-family: var(--cjk-serif);
    font-size: var(--fs-xl);
    font-weight: var(--fw-medium);
    line-height: 1;
  }
  .tier-en {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.14em;
    line-height: 1;
  }

  .tier--s .tier-label {
    background: oklch(0.95 0.04 30);
    color: oklch(0.40 0.16 25);
  }
  .tier--a .tier-label {
    background: oklch(0.95 0.04 65);
    color: oklch(0.40 0.12 55);
  }
  .tier--b .tier-label {
    background: oklch(0.95 0.03 140);
    color: oklch(0.38 0.10 140);
  }
  .tier--c .tier-label {
    background: oklch(0.95 0.01 250);
    color: var(--ink-3);
  }
  .tier--d .tier-label {
    background: oklch(0.93 0.02 280);
    color: oklch(0.42 0.10 280);
  }

  :global(html.dark) .tier--s .tier-label {
    background: oklch(0.25 0.06 30);
    color: oklch(0.78 0.14 25);
  }
  :global(html.dark) .tier--a .tier-label {
    background: oklch(0.25 0.05 65);
    color: oklch(0.78 0.11 55);
  }
  :global(html.dark) .tier--b .tier-label {
    background: oklch(0.25 0.04 140);
    color: oklch(0.75 0.09 140);
  }
  :global(html.dark) .tier--c .tier-label {
    background: oklch(0.22 0.01 250);
    color: var(--ink-3);
  }
  :global(html.dark) .tier--d .tier-label {
    background: oklch(0.22 0.03 280);
    color: oklch(0.70 0.08 280);
  }

  /* ── BOOK TILES ── */
  .tier-books {
    display: flex;
    flex-wrap: wrap;
    padding: var(--sp-14) var(--sp-16);
    gap: var(--sp-14);
    align-content: flex-start;
  }

  .book-tile {
    position: relative;
    flex: 0 0 100px;
    max-width: 100px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
    cursor: default;
  }

  /* ── Cover ── */
  .tile-cover-wrap {
    width: 100px;
    height: 140px;
    overflow: hidden;
    border: var(--sp-hairline) solid var(--rule-soft);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .book-tile:hover .tile-cover-wrap {
    border-color: var(--accent-front);
    box-shadow: 0 2px 12px color-mix(in oklch, var(--accent-front) 15%, transparent);
  }

  .tile-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Fallback: first char of title */
  .tile-fallback {
    width: 100%;
    height: 100%;
    background: linear-gradient(
      145deg,
      color-mix(in oklch, var(--accent-front) 6%, var(--paper-2)),
      color-mix(in oklch, var(--accent-back) 8%, var(--paper-2))
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tile-fallback span {
    font-family: var(--cjk-serif);
    font-size: 36px;
    font-weight: var(--fw-medium);
    color: var(--ink-3);
    opacity: 0.45;
    line-height: 1;
  }

  /* ── Meta (title + author) ── */
  .tile-meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding: 0 var(--sp-2);
  }
  .tile-title {
    font-family: var(--cjk-serif);
    font-size: var(--fs-xs);
    font-weight: var(--fw-medium);
    color: var(--ink);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tile-title-en {
    font-family: var(--serif);
    font-size: 10px;
    font-style: italic;
    font-weight: var(--fw-light);
    color: var(--ink-3);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tile-author {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    margin-top: 1px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Review popup on hover ── */
  .tile-review-popup {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    width: 200px;
    padding: var(--sp-10) var(--sp-12);
    background: var(--paper);
    border: var(--sp-hairline) solid var(--rule);
    box-shadow: 0 4px 20px color-mix(in oklch, var(--ink) 8%, transparent);
    z-index: 20;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s, visibility 0.15s, transform 0.15s;
  }
  .book-tile:hover .tile-review-popup {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(8px);
  }
  .tile-review {
    font-family: var(--cjk-serif);
    font-size: var(--fs-xs);
    color: var(--ink-2);
    line-height: var(--lh-prose);
    margin: 0;
    font-weight: var(--fw-light);
  }
  .tile-year {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--ink-3);
    margin-top: var(--sp-4);
    text-align: right;
  }

  .tier-empty {
    color: var(--ink-3);
    font-family: var(--mono);
    font-size: var(--fs-sm);
    display: flex;
    align-items: center;
    padding: var(--sp-8);
  }

  /* ── FOOTER ── */
  .books-foot {
    margin-top: var(--sp-44);
    padding-top: var(--sp-22);
    border-top: var(--sp-hairline) solid var(--rule);
  }
  .books-note {
    font-family: var(--serif);
    font-size: var(--fs-sm);
    color: var(--ink-3);
    font-style: italic;
    font-weight: var(--fw-light);
    line-height: var(--lh-prose);
    margin: 0 0 var(--sp-4);
  }
  .books-note.cjk {
    font-family: var(--cjk-serif);
    font-style: normal;
  }
  .books-note.cjk em {
    font-style: normal;
    text-decoration: underline;
    text-decoration-style: var(--cjk-em-line);
    text-decoration-color: var(--accent-front);
    text-decoration-thickness: var(--cjk-em-thickness);
    text-underline-offset: var(--cjk-em-offset);
  }
  .books-note:not(.cjk) em {
    color: var(--accent-back-ink);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .tier {
      grid-template-columns: 52px 1fr;
    }
    .tier-zh { font-size: var(--fs-lg); }
    .tier-books {
      padding: var(--sp-10) var(--sp-10);
      gap: var(--sp-10);
    }
    .book-tile { width: 80px; }
    .tile-cover-wrap {
      width: 80px;
      height: 112px;
    }
    .tile-title { font-size: 11px; }
    .tile-review-popup {
      width: 170px;
    }
  }
</style>
