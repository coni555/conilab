---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import Kicker from "../../components/Kicker.astro";

const all = await getCollection("notes");
const notes = all
  .filter((n) => !n.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.published_at).getTime() -
      new Date(a.data.published_at).getTime(),
  );

const fmtDate = (d: Date | string) => {
  const dt = new Date(d);
  const m = String(dt.getMonth() + 1).padStart(2, "0");
  const day = String(dt.getDate()).padStart(2, "0");
  return `${dt.getFullYear()}.${m}.${day}`;
};
const slugOf = (n: (typeof notes)[number]) =>
  n.data.slug ?? n.id.replace(/\.(md|mdx)$/, "");
---

<Base
  title="Notes — conilab"
  description="Quick takes — book marginalia, half-thoughts, one-line observations. The other face of the coin."
>
  <section class="almanac">
    <div class="wrap">
      <header class="almanac-head">
        <Kicker text="notes · 短想登记簿" />
        <h1 class="almanac-title">
          The margins — <em>kept brief</em>
        </h1>
        <p class="almanac-lede cjk" data-lang="zh" lang="zh">
          硬币的另一面：<em>三言两语</em>就能说完的短想——书摘、灵感闪过、一句话观察。
        </p>
        <p class="almanac-lede-en" data-lang="en" lang="en">
          The other face of the coin: <em>quick takes</em> — book marginalia,
          half-thoughts, one-line observations.
        </p>
        <dl class="almanac-meta">
          <dt>Total</dt><dd>{notes.length} entr{notes.length === 1 ? "y" : "ies"}</dd>
          <dt>Length</dt><dd>brief — by design</dd>
          <dt>Cadence</dt><dd>whenever something lands</dd>
          <dt>Languages</dt><dd>whichever it lands in</dd>
        </dl>
      </header>

      {notes.length === 0 ? (
        <div class="empty">
          <p data-lang="zh" class="cjk">还没有登记任何短想。这里现在还空着。</p>
          <p data-lang="en">No notes yet. This face of the coin is still empty.</p>
        </div>
      ) : (
        <ol class="entries">
          {notes.map((n) => (
            <li class="entry">
              <a class="entry-link" href={`/notes/${slugOf(n)}/`}>
                <span class="entry-date">{fmtDate(n.data.published_at)}</span>
                <span class="entry-titles">
                  {n.data.title_zh && (
                    <span class="entry-title-zh cjk" lang="zh">{n.data.title_zh}</span>
                  )}
                  {n.data.title_en && (
                    <span class="entry-title-en">{n.data.title_en}</span>
                  )}
                </span>
                <span class="entry-tags">
                  {(n.data.tags ?? []).slice(0, 3).join(" · ")}
                </span>
                <span class="entry-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>
</Base>

<style>
  .almanac { padding: var(--sp-44) 0 var(--sp-96); }

  .almanac-head {
    border-bottom: var(--sp-hairline) solid var(--rule);
    padding-bottom: var(--sp-32);
    margin-bottom: var(--sp-44);
  }
  .almanac-title {
    font-family: var(--serif);
    font-size: clamp(var(--fs-7xl), 4vw, 48px);
    line-height: 1.1;
    margin: var(--sp-12) 0 var(--sp-18);
    color: var(--ink);
    font-weight: var(--fw-medium);
    letter-spacing: -0.01em;
  }
  .almanac-title :global(em) {
    font-style: italic;
    font-weight: var(--fw-light);
    color: var(--accent-back-ink);
  }
  .almanac-lede {
    font-family: var(--cjk-serif);
    font-size: var(--fs-xl);
    line-height: var(--lh-prose);
    color: var(--ink-2);
    max-width: 60ch;
    margin: 0 0 var(--sp-8);
    font-weight: var(--fw-light);
  }
  .almanac-lede :global(em) {
    font-style: normal;
    color: inherit;
    text-decoration: underline;
    text-decoration-style: var(--cjk-em-line);
    text-decoration-color: var(--accent-back);
    text-decoration-thickness: var(--cjk-em-thickness);
    text-underline-offset: var(--cjk-em-offset);
  }
  .almanac-lede-en {
    font-family: var(--serif);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    color: var(--ink-3);
    font-style: italic;
    max-width: 60ch;
    margin: 0 0 var(--sp-22);
    font-weight: var(--fw-light);
  }
  .almanac-lede-en :global(em) {
    color: var(--accent-back-ink);
    font-weight: var(--fw-normal);
  }

  .almanac-meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: var(--sp-22);
    row-gap: var(--sp-6);
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    margin: 0;
    max-width: 380px;
  }
  .almanac-meta dt {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-3);
  }
  .almanac-meta dd {
    margin: 0;
    color: var(--ink-2);
    font-family: var(--sans);
    font-size: var(--fs-md);
  }

  /* ── ENTRY LIST ── */
  .entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .entry {
    border-bottom: var(--sp-hairline) solid var(--rule);
  }
  .entry:last-child { border-bottom: none; }

  .entry-link {
    display: grid;
    grid-template-columns: 110px 1fr 160px 40px;
    align-items: baseline;
    gap: var(--sp-22);
    padding: var(--sp-22) 0;
    color: var(--ink);
    transition: background var(--dur-quick);
  }
  .entry-link:hover {
    background: color-mix(in oklch, var(--accent-back) 4%, transparent);
  }
  .entry-link:hover .entry-arrow {
    transform: translateX(4px);
    color: var(--accent-back);
  }

  @media (max-width: 720px) {
    .entry-link {
      grid-template-columns: max-content 1fr max-content;
      grid-template-areas:
        "date tags arrow"
        "title title title";
      row-gap: var(--sp-8);
      padding: var(--sp-18) 0;
    }
    .entry-date  { grid-area: date; }
    .entry-titles { grid-area: title; }
    .entry-tags  { grid-area: tags; }
    .entry-arrow { grid-area: arrow; }
  }

  .entry-date {
    font-family: var(--mono);
    font-size: var(--fs-sm);
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }

  .entry-titles {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    min-width: 0;
  }
  .entry-title-zh {
    font-family: var(--cjk-serif);
    font-size: var(--fs-xl);
    line-height: 1.3;
    color: var(--ink);
    font-weight: var(--fw-medium);
  }
  .entry-title-en {
    font-family: var(--serif);
    font-size: var(--fs-md);
    line-height: 1.3;
    color: var(--ink-3);
    font-style: italic;
    font-weight: var(--fw-light);
  }

  .entry-tags {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    text-align: right;
  }
  @media (max-width: 720px) {
    .entry-tags { text-align: left; }
  }

  .entry-arrow {
    font-family: var(--serif);
    font-size: var(--fs-xl);
    color: var(--ink-3);
    text-align: right;
    transition: transform var(--dur-quick), color var(--dur-quick);
  }

  .empty {
    padding: var(--sp-72) 0;
    color: var(--ink-3);
    font-family: var(--serif);
    font-size: var(--fs-lg);
    display: grid;
    gap: var(--sp-10);
    max-width: 50ch;
  }
  .empty [data-lang="zh"] { font-family: var(--cjk-serif); }
  .empty [data-lang="en"] { font-style: italic; }
</style>
