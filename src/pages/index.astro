---
import Base from "../layouts/Base.astro";
import ChapterHead from "../components/ChapterHead.astro";
import ColophonCard from "../components/ColophonCard.astro";
import Kicker from "../components/Kicker.astro";
import CoinGlyph from "../components/CoinGlyph.astro";

const colophonEntries = [
  { label: "Reading",  value: "TBD — 待登记" },
  { label: "Writing",  value: "First long-form, brewing", accent: true, href: "#" },
  { label: "Shipping", value: "0 entries · 试验簿初开" },
  { label: "Watching", value: "AI alignment notes" },
];
---

<Base>
  <!-- ============================================================
       HERO — 对联式中英并置（conilab signature：硬币双面）
       ============================================================ -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-rubric">
        <CoinGlyph variant="ring" />
        <span>conilab.cn — a notebook with two faces</span>
        <CoinGlyph variant="ring" />
      </div>

      <div class="hero-couplet">
        <div class="hero-side hero-side--front" data-side="front">
          <div class="hero-side-tag">正面 · ZH</div>
          <h1 class="hero-title cjk" lang="zh">
            两面读<br />
            一遍世界
          </h1>
          <p class="hero-sub cjk" lang="zh">
            一份只发<em>三千字</em>以上长文的笔记本。<br />
            每一篇都被读两次：一次中文，一次英文。
          </p>
        </div>

        <div class="hero-divider" aria-hidden="true">
          <CoinGlyph variant="dot" size="1.4em" />
        </div>

        <div class="hero-side hero-side--back" data-side="back">
          <div class="hero-side-tag">REVERSE · EN</div>
          <h1 class="hero-title">
            Read <em>twice</em>,<br />
            once <em>each side</em>.
          </h1>
          <p class="hero-sub">
            A notebook that publishes only when a piece reaches <em>3000 字</em> —
            and only after it has been written in both languages.
          </p>
        </div>
      </div>

      <!-- 水印叠底（借自 design-ref-editorial 招式：装饰性大字叠在内容后面）-->
      <div class="hero-watermark" aria-hidden="true">⊙</div>

      <div class="hero-foot">
        <dl class="hero-meta">
          <dt>Min length</dt>   <dd>3000 字</dd>
          <dt>Languages</dt>    <dd>中文 · English</dd>
          <dt>Cadence</dt>      <dd>~1 long-form / fortnight</dd>
          <dt>Faces</dt>        <dd>two — by design</dd>
        </dl>

        <ColophonCard
          bureau="conilab.cn"
          bureauList={["conilab.cn", "github/coni555"]}
          entries={colophonEntries}
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       CHAPTER Ⅰ · ARTICLES
       ============================================================ -->
  <section class="chapter" id="articles">
    <div class="wrap">
      <ChapterHead num="Ⅰ" label="ARTICLES" allHref="/articles">
        The journal — <em>read twice, kept once</em>
      </ChapterHead>

      <div class="placeholder">
        <Kicker text="no entries yet · 暂无文章" accent />
        <div class="bilingual">
          <p data-lang="zh" class="cjk">
            这里很快会出现第一篇<em>三千字以上</em>的长文。每篇登记两次：
            一面是<em>中文</em>，一面是<em>English</em>。
          </p>
          <p data-lang="en">
            The first <em>≥3000-字</em> piece is brewing. Each entry is registered
            twice — once on the <em>front</em> face, once on the <em>reverse</em>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CHAPTER Ⅱ · PRINCIPLES
       (替代 lixiaolai-style ABOUT；不出现真实身份)
       ============================================================ -->
  <section class="chapter" id="principles">
    <div class="wrap">
      <ChapterHead num="Ⅱ" label="PRINCIPLES" side="back">
        What this notebook <em>refuses</em>
      </ChapterHead>

      <ol class="principles">
        <li>
          <span class="p-num">i</span>
          <div class="bilingual">
            <p data-lang="zh" class="cjk">
              不发任何<em>低于三千字</em>的内容。短想法去别处。
            </p>
            <p data-lang="en">
              Nothing under <em>3000 字</em> ships here. Shorter thoughts live elsewhere.
            </p>
          </div>
        </li>
        <li>
          <span class="p-num">ii</span>
          <div class="bilingual">
            <p data-lang="zh" class="cjk">
              每篇都要被<em>读两次</em>：一次写、一次译。译稿不是附加，是同一篇的另一面。
            </p>
            <p data-lang="en">
              Each piece is <em>read twice</em>: once written, once translated.
              The translation isn't a supplement — it's the other face of the same coin.
            </p>
          </div>
        </li>
        <li>
          <span class="p-num">iii</span>
          <div class="bilingual">
            <p data-lang="zh" class="cjk">
              不暴露任何<em>真实身份信息</em>。这里只有一个网名 @coni 和一组想法。
            </p>
            <p data-lang="en">
              No <em>real-world identity</em> appears here. Only a handle (@coni)
              and a set of ideas.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>
</Base>

<style>
  /* ─── HERO ─── */
  .hero { padding: var(--sp-72) 0 var(--sp-80); position: relative; overflow: hidden; }

  .hero-rubric {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--sp-44);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-14);
  }

  /* —— 对联式中英并置（conilab 招牌版式） —— */
  .hero-couplet {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--sp-44);
    align-items: stretch;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .hero-couplet {
      grid-template-columns: 1fr;
      gap: var(--sp-32);
    }
    .hero-divider { display: none; }
  }
  .hero-side { padding: var(--sp-12) 0; }
  .hero-side--back { text-align: right; }
  @media (max-width: 900px) {
    .hero-side--back { text-align: left; }
  }
  .hero-side-tag {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: var(--sp-18);
    padding-bottom: var(--sp-6);
    border-bottom: var(--sp-hairline) solid currentColor;
    display: inline-block;
  }
  .hero-side--front .hero-side-tag { color: var(--accent-front); }
  .hero-side--back  .hero-side-tag { color: var(--accent-back); }

  .hero-title {
    font-family: var(--serif);
    font-weight: var(--fw-normal);
    font-size: clamp(var(--fs-9xl), 5.6vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0 0 var(--sp-22);
    color: var(--ink);
    font-variation-settings: "opsz" 72;
  }
  .hero-side--front .hero-title { font-family: var(--cjk-serif); }
  .hero-title :global(em) {
    font-style: italic;
    font-weight: var(--fw-light);
  }
  .hero-side--front .hero-title :global(em) { color: var(--accent-front-ink); }
  .hero-side--back  .hero-title :global(em) { color: var(--accent-back-ink); }

  .hero-sub {
    font-family: var(--serif);
    font-size: var(--fs-xl);
    line-height: var(--lh-relaxed);
    color: var(--ink-2);
    max-width: 30ch;
    margin: 0;
    font-weight: var(--fw-light);
  }
  .hero-side--front .hero-sub { font-family: var(--cjk-serif); }
  .hero-side--back  .hero-sub { margin-left: auto; }
  .hero-sub :global(em) { font-style: italic; }
  .hero-side--front .hero-sub :global(em) { color: var(--accent-front-ink); }
  .hero-side--back  .hero-sub :global(em) { color: var(--accent-back-ink); }

  /* 中央分隔：垂直 hairline + 中点 ⊙ —— "硬币剖面" */
  .hero-divider {
    width: var(--sp-hairline);
    background: var(--rule);
    position: relative;
    align-self: stretch;
    margin: 0 var(--sp-12);
  }
  .hero-divider :global(.coin-glyph) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--paper);
    padding: var(--sp-12) var(--sp-4);
    color: var(--ink-3);
  }

  /* 水印叠底（design-ref-editorial 招式：装饰大字垫底）*/
  .hero-watermark {
    position: absolute;
    right: -2vw;
    bottom: -8vw;
    font-size: clamp(280px, 38vw, 540px);
    line-height: 0.85;
    color: color-mix(in oklch, var(--accent-front) 5%, var(--paper));
    user-select: none;
    pointer-events: none;
    z-index: 0;
    font-weight: 200;
  }

  /* —— hero foot：meta + colophon 卡 —— */
  .hero-foot {
    margin-top: var(--sp-72);
    padding-top: var(--sp-32);
    border-top: var(--sp-hairline) solid var(--rule);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-44);
    align-items: start;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .hero-foot { grid-template-columns: 1fr; gap: var(--sp-32); }
  }
  .hero-meta {
    font-family: var(--mono);
    font-size: var(--fs-sm);
    color: var(--ink-3);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--sp-6) var(--sp-18);
    max-width: 380px;
    margin: 0;
  }
  .hero-meta dt {
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero-meta dd {
    margin: 0;
    color: var(--ink-2);
    font-family: var(--sans);
    font-size: var(--fs-md);
  }

  /* ─── CHAPTER ─── */
  .chapter { padding: var(--sp-32) 0; position: relative; z-index: 1; }

  .placeholder {
    padding: var(--sp-48) 0;
    display: grid;
    gap: var(--sp-18);
    max-width: 64ch;
  }
  .bilingual {
    display: grid;
    gap: var(--sp-10);
    font-family: var(--serif);
    font-size: var(--fs-xl);
    line-height: var(--lh-prose);
    color: var(--ink-2);
  }
  .bilingual p { margin: 0; }
  .bilingual [data-lang="zh"] { font-family: var(--cjk-serif); }
  .bilingual [data-lang="en"] {
    font-style: italic;
    color: var(--ink-3);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
  }
  .bilingual [data-lang="zh"] :global(em) {
    font-style: normal;
    color: inherit;
    text-decoration: underline;
    text-decoration-style: var(--cjk-em-line);
    text-decoration-color: var(--accent-front);
    text-decoration-thickness: var(--cjk-em-thickness);
    text-underline-offset: var(--cjk-em-offset);
  }
  .bilingual [data-lang="en"] :global(em) {
    color: var(--accent-front-ink);
  }

  /* ─── PRINCIPLES list ─── */
  .principles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-30);
    max-width: 70ch;
  }
  .principles li {
    display: grid;
    grid-template-columns: var(--sp-44) 1fr;
    gap: var(--sp-18);
    padding-bottom: var(--sp-22);
    border-bottom: var(--sp-hairline) dashed var(--rule);
  }
  .principles li:last-child { border-bottom: none; }
  .p-num {
    font-family: var(--serif);
    font-style: italic;
    font-weight: var(--fw-light);
    font-size: var(--fs-3xl);
    color: var(--accent-back);
    line-height: 1;
    padding-top: var(--sp-2);
  }
</style>
