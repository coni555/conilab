---
import Base from "../layouts/Base.astro";
import ChapterHead from "../components/ChapterHead.astro";
import ColophonCard from "../components/ColophonCard.astro";
import Kicker from "../components/Kicker.astro";
import CoinGlyph from "../components/CoinGlyph.astro";
import { getCollection } from "astro:content";

const all = await getCollection("articles");
const articles = all
  .filter((a) => !a.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.published_at).getTime() -
      new Date(a.data.published_at).getTime(),
  );

const fmtDate = (d: Date | string) => {
  const dt = new Date(d);
  return `${dt.getFullYear()}.${String(dt.getMonth() + 1).padStart(2, "0")}.${String(dt.getDate()).padStart(2, "0")}`;
};
const slugOf = (a: (typeof articles)[number]) =>
  a.data.slug ?? a.id.replace(/\.(md|mdx)$/, "");

const colophonEntries = [
  { label: "Reading",  value: "《上行》" },
  { label: "Writing",  value: "酝酿中 · brewing", accent: true },
  { label: "Shipping", value: `${articles.length} entr${articles.length === 1 ? "y" : "ies"} · 已登记` },
  { label: "Watching", value: "AI alignment notes" },
];
---

<Base>
  <!-- ============================================================
       HERO — 对联式中英并置（conilab signature：硬币双面）
       ============================================================ -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-rubric">
        <CoinGlyph variant="ring" />
        <span>conilab.cn — a notebook with two faces</span>
        <CoinGlyph variant="ring" />
      </div>

      <div class="hero-couplet">
        <div class="hero-side hero-side--front" data-side="front" data-lang="zh">
          <div class="hero-side-tag">正面 · ZH</div>
          <h1 class="hero-title cjk" lang="zh">
            正面读一次<br />
            <em>翻过来</em>再读一次
          </h1>
          <p class="hero-sub cjk" lang="zh">
            不是<em>翻译</em>。是同一个想法落在<br />
            另一种语言的土壤上，长出<br />
            稍微不同的形状。
          </p>
        </div>

        <div class="hero-divider" aria-hidden="true" data-lang="both">
          <CoinGlyph variant="dot" size="1.4em" />
        </div>

        <div class="hero-side hero-side--back" data-side="back" data-lang="en">
          <div class="hero-side-tag">REVERSE · EN</div>
          <h1 class="hero-title">
            Read it once.<br />
            Now <em>turn it over</em>.
          </h1>
          <p class="hero-sub">
            Not a <em>translation</em>. The same thought,
            landing in another tongue — and growing
            slightly different roots.
          </p>
        </div>
      </div>

      <!-- 水印叠底（借自 design-ref-editorial 招式：装饰性大字叠在内容后面）-->
      <div class="hero-watermark" aria-hidden="true">⊙</div>
    </div>
  </section>

  <!-- ============================================================
       CHAPTER Ⅰ · ARTICLES（提前到 hero 之后，让最新文章首屏可见）
       ============================================================ -->
  <section class="chapter chapter--articles" id="articles">
    <div class="wrap">
      <ChapterHead num="Ⅰ" label="ARTICLES" allHref="/articles">
        The journal — <em>read twice, kept once</em>
      </ChapterHead>

      {articles.length === 0 ? (
        <div class="placeholder">
          <Kicker text="no entries yet · 暂无文章" accent />
          <div class="bilingual">
            <p data-lang="zh" class="cjk">
              第一篇<em>三千字以上</em>的长文正在酿。同一个核——
              一次落在<em>中文</em>里，一次落在<em>English</em>里。
            </p>
            <p data-lang="en">
              The first <em>≥3000-字</em> piece is brewing. One core —
              landing once in <em>中文</em>, once in <em>English</em>.
            </p>
          </div>
        </div>
      ) : (
        <ol class="recent">
          {articles.slice(0, 5).map((a) => (
            <li class="recent-item">
              <a class="recent-link" href={`/articles/${slugOf(a)}/`}>
                <span class="recent-date">{fmtDate(a.data.published_at)}</span>
                <span class="recent-titles">
                  <span class="recent-title-zh cjk" lang="zh">{a.data.title_zh}</span>
                  <span class="recent-title-en">{a.data.title_en}</span>
                </span>
                <span class="recent-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
          <li class="recent-all">
            <a href="/articles/" class="recent-all-link">
              View all {articles.length} entr{articles.length === 1 ? "y" : "ies"} <span aria-hidden="true">→</span>
            </a>
          </li>
        </ol>
      )}
    </div>
  </section>

  <!-- ============================================================
       REGISTRY — 试验登记卡（meta + colophon），从 hero-foot 升级为独立段
       ============================================================ -->
  <section class="registry">
    <div class="wrap">
      <div class="registry-grid">
        <dl class="hero-meta">
          <dt>Min length</dt>   <dd>3000 字</dd>
          <dt>Languages</dt>    <dd>中文 · English</dd>
          <dt>Cadence</dt>      <dd>~1 long-form / fortnight</dd>
          <dt>Faces</dt>        <dd>two — by design</dd>
        </dl>

        <ColophonCard
          bureau="conilab.cn"
          bureauList={["conilab.cn", "github/coni555"]}
          entries={colophonEntries}
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       CHAPTER Ⅱ · PRINCIPLES
       (替代 lixiaolai-style ABOUT；不出现真实身份)
       ============================================================ -->
  <section class="chapter" id="principles">
    <div class="wrap">
      <ChapterHead num="Ⅱ" label="PRINCIPLES" side="back">
        What an article <em>refuses</em>
      </ChapterHead>

      <ol class="principles">
        <li>
          <span class="p-num">i</span>
          <div class="bilingual">
            <p data-lang="zh" class="cjk">
              不发任何<em>低于三千字</em>的内容。短想法去别处。
            </p>
            <p data-lang="en">
              Nothing under <em>3000 字</em> ships here. Shorter thoughts live elsewhere.
            </p>
          </div>
        </li>
        <li>
          <span class="p-num">ii</span>
          <div class="bilingual">
            <p data-lang="zh" class="cjk">
              一个想法只用<em>母语</em>写一遍，它还没<em>完成</em>。翻过来再写一遍，才是同一枚硬币的两面。
            </p>
            <p data-lang="en">
              A thought written only in its <em>native tongue</em> isn't <em>finished</em>.
              Written again from the other side, it becomes both faces of the same coin.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>
</Base>

<style>
  /* ─── HERO ─── */
  .hero { padding: var(--sp-48) 0 var(--sp-56); position: relative; overflow: hidden; }

  /* —— 入场动画：rubric → ZH 侧 → 中央 ⊙ → EN 侧 错峰淡入上滑 —— */
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-rubric,
  .hero-side--front,
  .hero-divider,
  .hero-side--back {
    animation: hero-rise 700ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
  }
  .hero-rubric       { animation-delay:   0ms; }
  .hero-side--front  { animation-delay: 120ms; }
  .hero-divider      { animation-delay: 200ms; }
  .hero-side--back   { animation-delay: 280ms; }
  @media (prefers-reduced-motion: reduce) {
    .hero-rubric,
    .hero-side--front,
    .hero-divider,
    .hero-side--back { animation: none; }
  }

  .hero-rubric {
    font-family: var(--mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--sp-28);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-14);
  }

  /* —— 对联式中英并置（conilab 招牌版式） —— */
  .hero-couplet {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--sp-44);
    align-items: stretch;
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .hero-couplet {
      grid-template-columns: 1fr;
      gap: var(--sp-32);
    }
    .hero-divider { display: none; }
  }
  .hero-side { padding: var(--sp-12) 0; }
  .hero-side--back { text-align: right; }
  @media (max-width: 900px) {
    .hero-side--back { text-align: left; }
  }

  /* —— 单语模式：折叠 couplet 为单列，hero-divider 隐藏 —— */
  :global(html.show-zh) .hero-couplet,
  :global(html.show-en) .hero-couplet {
    grid-template-columns: 1fr;
  }
  :global(html.show-zh) .hero-divider,
  :global(html.show-en) .hero-divider { display: none; }
  /* EN 单语：标题居左 + sub 也居左（覆盖原 back 右对齐） */
  :global(html.show-en) .hero-side--back { text-align: left; }
  :global(html.show-en) .hero-side--back .hero-sub { margin-left: 0; }
  .hero-side-tag {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: var(--sp-18);
    padding-bottom: var(--sp-6);
    border-bottom: var(--sp-hairline) solid currentColor;
    display: inline-block;
  }
  .hero-side--front .hero-side-tag { color: var(--accent-front); }
  .hero-side--back  .hero-side-tag { color: var(--accent-back); }

  .hero-title {
    font-family: var(--serif);
    font-weight: var(--fw-normal);
    font-size: clamp(var(--fs-9xl), 5.6vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0 0 var(--sp-22);
    color: var(--ink);
    font-variation-settings: "opsz" 72;
  }
  .hero-side--front .hero-title { font-family: var(--cjk-serif); }
  .hero-title :global(em) { font-weight: var(--fw-light); }
  .hero-side--front .hero-title :global(em) {
    /* CJK em：不 italic，走 globals.css 的 dotted 蓝下划线 */
    color: var(--accent-front-ink);
  }
  .hero-side--back .hero-title :global(em) {
    font-style: italic;
    color: var(--accent-back-ink);
  }

  .hero-sub {
    font-family: var(--serif);
    font-size: var(--fs-xl);
    line-height: var(--lh-relaxed);
    color: var(--ink-2);
    max-width: 30ch;
    margin: 0;
    font-weight: var(--fw-light);
  }
  .hero-side--front .hero-sub { font-family: var(--cjk-serif); }
  .hero-side--back  .hero-sub { margin-left: auto; }
  /* 英文段 em italic，中文段走 globals.css 的 CJK em（normal + 蓝 dotted） */
  .hero-side--front .hero-sub :global(em) { color: var(--accent-front-ink); }
  .hero-side--back  .hero-sub :global(em) {
    font-style: italic;
    color: var(--accent-back-ink);
  }

  /* 中央分隔：垂直 hairline + 中点 ⊙ —— "硬币剖面" */
  .hero-divider {
    width: var(--sp-hairline);
    background: var(--rule);
    position: relative;
    align-self: stretch;
    margin: 0 var(--sp-12);
  }
  .hero-divider :global(.coin-glyph) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--paper);
    padding: var(--sp-12) var(--sp-4);
    color: var(--ink-3);
  }

  /* 水印叠底（design-ref-editorial 招式：装饰大字垫底）*/
  .hero-watermark {
    position: absolute;
    right: -2vw;
    bottom: -8vw;
    font-size: clamp(280px, 38vw, 540px);
    line-height: 0.85;
    color: color-mix(in oklch, var(--accent-front) 5%, var(--paper));
    user-select: none;
    pointer-events: none;
    z-index: 0;
    font-weight: 200;
    /* 慢速旋转：240s/圈，几乎察觉不到的 living quality */
    transform-origin: center;
    animation: watermark-drift 240s linear infinite;
  }
  @keyframes watermark-drift {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-watermark { animation: none; }
  }

  /* —— REGISTRY：试验登记卡（meta + colophon）—— */
  .registry {
    padding: var(--sp-32) 0 var(--sp-48);
    border-top: var(--sp-hairline) solid var(--rule);
    margin-top: var(--sp-32);
  }
  .registry-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-44);
    align-items: start;
  }
  @media (max-width: 900px) {
    .registry-grid { grid-template-columns: 1fr; gap: var(--sp-32); }
  }
  .hero-meta {
    font-family: var(--mono);
    font-size: var(--fs-sm);
    color: var(--ink-3);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--sp-6) var(--sp-18);
    max-width: 380px;
    margin: 0;
  }
  .hero-meta dt {
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero-meta dd {
    margin: 0;
    color: var(--ink-2);
    font-family: var(--sans);
    font-size: var(--fs-md);
  }

  /* ─── CHAPTER ─── */
  .chapter { padding: var(--sp-32) 0; position: relative; z-index: 1; }

  .placeholder {
    padding: var(--sp-48) 0;
    display: grid;
    gap: var(--sp-18);
    max-width: 64ch;
  }
  .bilingual {
    display: grid;
    gap: var(--sp-10);
    font-family: var(--serif);
    font-size: var(--fs-xl);
    line-height: var(--lh-prose);
    color: var(--ink-2);
  }
  .bilingual p { margin: 0; }
  .bilingual [data-lang="zh"] { font-family: var(--cjk-serif); }
  .bilingual [data-lang="en"] {
    font-style: italic;
    color: var(--ink-3);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
  }
  .bilingual [data-lang="zh"] :global(em) {
    font-style: normal;
    color: inherit;
    text-decoration: underline;
    text-decoration-style: var(--cjk-em-line);
    text-decoration-color: var(--accent-front);
    text-decoration-thickness: var(--cjk-em-thickness);
    text-underline-offset: var(--cjk-em-offset);
  }
  .bilingual [data-lang="en"] :global(em) {
    color: var(--accent-front-ink);
  }

  /* ─── RECENT articles list (homepage Ⅰ chapter) ─── */
  .recent {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 70ch;
  }
  .recent-item {
    border-bottom: var(--sp-hairline) solid var(--rule);
  }
  .recent-link {
    display: grid;
    grid-template-columns: 100px 1fr 40px;
    gap: var(--sp-22);
    align-items: baseline;
    padding: var(--sp-18) 0;
    color: var(--ink);
    transition: background var(--dur-quick);
  }
  .recent-link:hover {
    background: color-mix(in oklch, var(--accent-front) 4%, transparent);
  }
  .recent-link:hover .recent-arrow {
    transform: translateX(4px);
    color: var(--accent-front);
  }
  .recent-date {
    font-family: var(--mono);
    font-size: var(--fs-sm);
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  .recent-titles {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .recent-title-zh {
    font-family: var(--cjk-serif);
    font-size: var(--fs-xl);
    color: var(--ink);
    font-weight: var(--fw-medium);
    line-height: 1.3;
  }
  .recent-title-en {
    font-family: var(--serif);
    font-size: var(--fs-md);
    color: var(--ink-3);
    font-style: italic;
    line-height: 1.3;
  }
  .recent-arrow {
    font-family: var(--serif);
    color: var(--ink-3);
    text-align: right;
    transition: transform var(--dur-quick), color var(--dur-quick);
  }
  .recent-all {
    padding-top: var(--sp-22);
    list-style: none;
  }
  .recent-all-link {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-back);
    border-bottom: var(--sp-hairline) solid color-mix(in oklch, var(--accent-back) 50%, var(--rule));
    padding-bottom: var(--sp-2);
  }
  .recent-all-link:hover { color: var(--accent-back-ink); }
  @media (max-width: 720px) {
    .recent-link {
      grid-template-columns: max-content 1fr max-content;
      gap: var(--sp-12);
    }
  }

  /* ─── PRINCIPLES list ─── */
  .principles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-30);
    max-width: 70ch;
  }
  .principles li {
    display: grid;
    grid-template-columns: var(--sp-44) 1fr;
    gap: var(--sp-18);
    padding-bottom: var(--sp-22);
    border-bottom: var(--sp-hairline) dashed var(--rule);
  }
  .principles li:last-child { border-bottom: none; }
  .p-num {
    font-family: var(--serif);
    font-style: italic;
    font-weight: var(--fw-light);
    font-size: var(--fs-3xl);
    color: var(--accent-back);
    line-height: 1;
    padding-top: var(--sp-2);
  }
</style>
