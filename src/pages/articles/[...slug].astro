---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { marked } from "marked";

export async function getStaticPaths() {
  const all = await getCollection("articles");
  const articles = all
    .filter((a) => !a.data.draft)
    .sort(
      (a, b) =>
        new Date(b.data.published_at).getTime() -
        new Date(a.data.published_at).getTime(),
    );
  const slugOf = (a: (typeof articles)[number]) =>
    a.data.slug ?? a.id.replace(/\.(md|mdx)$/, "");

  return articles.map((a, i) => {
    const slug = slugOf(a);
    const newer = i > 0 ? articles[i - 1] : null;       // 排序为 desc，所以 i-1 是更新的
    const older = i < articles.length - 1 ? articles[i + 1] : null;
    return {
      params: { slug },
      props: {
        article: a,
        newer: newer
          ? { slug: slugOf(newer), title_zh: newer.data.title_zh, title_en: newer.data.title_en }
          : null,
        older: older
          ? { slug: slugOf(older), title_zh: older.data.title_zh, title_en: older.data.title_en }
          : null,
      },
    };
  });
}

const { article, newer, older } = Astro.props;
const { data, body } = article;

// 按 <!-- LANG:EN --> 切分双语 body；ZH marker 顺手清掉
const langZhMarker = /<!--\s*LANG:ZH\s*-->/g;
const langEnMarker = /<!--\s*LANG:EN\s*-->/;
const stripped = (body ?? "").replace(langZhMarker, "");
const [zhRaw = "", enRaw = ""] = stripped.split(langEnMarker).map((s) => s.trim());

const zhHtmlRaw = marked.parse(zhRaw, { async: false }) as string;
const enHtmlRaw = marked.parse(enRaw, { async: false }) as string;

interface TocItem { id: string; text: string; level: number }

function processHeadings(html: string, prefix: string) {
  const toc: TocItem[] = [];
  let i = 0;
  const out = html.replace(/<(h[23])([^>]*)>([\s\S]*?)<\/\1>/g, (_, tag, attrs, content) => {
    const level = parseInt(tag[1]);
    const text = content.replace(/<[^>]*>/g, "");
    const id = `${prefix}-${++i}`;
    toc.push({ id, text, level });
    return `<${tag}${attrs} id="${id}">${content}</${tag}>`;
  });
  return { html: out, toc };
}

const { html: zhHtml, toc: zhToc } = processHeadings(zhHtmlRaw, "zh");
const { html: enHtml, toc: enToc } = processHeadings(enHtmlRaw, "en");
const hasToc = zhToc.length > 0 || enToc.length > 0;

const dateStr = new Date(data.published_at).toISOString().slice(0, 10);
const tagsStr = (data.tags ?? []).join(" · ");
---

<Base
  title={`${data.title_zh} / ${data.title_en} — conilab`}
  description={data.lede_en}
>
  <div class="reading-progress" aria-hidden="true"><div class="reading-progress-bar"></div></div>

  <article class="article">
    <div class="wrap">
      <header class="article-head">
        <div class="article-meta">
          <time datetime={dateStr}>{dateStr}</time>
          {tagsStr && <span class="dot">·</span>}
          {tagsStr && <span class="tags">{tagsStr}</span>}
        </div>
        <h1 class="article-title cjk" data-lang="zh" lang="zh">{data.title_zh}</h1>
        <h2 class="article-title-en" data-lang="en" lang="en">{data.title_en}</h2>
        <p class="article-lede cjk" data-lang="zh" lang="zh">{data.lede_zh}</p>
        <p class="article-lede-en" data-lang="en" lang="en">{data.lede_en}</p>
      </header>

      {hasToc && (
        <nav class="toc" aria-label="Table of contents">
          <div class="toc-inner">
            <span class="toc-label">Contents</span>
            <ol class="toc-list">
              {zhToc.map((h) => (
                <li class={`toc-item toc-h${h.level}`} data-lang="zh">
                  <a href={`#${h.id}`} class="toc-link" data-target={h.id}>{h.text}</a>
                </li>
              ))}
              {enToc.length > 0 && (
                <li class="toc-divider" aria-hidden="true">⊙</li>
              )}
              {enToc.map((h) => (
                <li class={`toc-item toc-h${h.level}`} data-lang="en">
                  <a href={`#${h.id}`} class="toc-link" data-target={h.id}>{h.text}</a>
                </li>
              ))}
            </ol>
          </div>
        </nav>
      )}

      <section class="article-body" data-lang="zh" lang="zh-CN">
        <div class="prose cjk" set:html={zhHtml}></div>
      </section>

      <div class="article-flip" aria-hidden="true">
        <span class="flip-rule"></span>
        <span class="flip-text">⊙ &nbsp; TURN IT OVER &nbsp; ⊙</span>
        <span class="flip-rule"></span>
      </div>

      <section class="article-body" data-lang="en" lang="en">
        <div class="prose" set:html={enHtml}></div>
      </section>

      {(newer || older) && (
        <nav class="article-nav" aria-label="Adjacent articles">
          {older ? (
            <a class="nav-link nav-prev" href={`/articles/${older.slug}/`}>
              <span class="nav-arrow" aria-hidden="true">←</span>
              <span class="nav-label">Older · 上一篇</span>
              <span class="nav-title-zh cjk" lang="zh">{older.title_zh}</span>
              <span class="nav-title-en">{older.title_en}</span>
            </a>
          ) : <span class="nav-link nav-prev nav-empty" aria-hidden="true"></span>}

          {newer ? (
            <a class="nav-link nav-next" href={`/articles/${newer.slug}/`}>
              <span class="nav-label">Newer · 下一篇</span>
              <span class="nav-arrow" aria-hidden="true">→</span>
              <span class="nav-title-zh cjk" lang="zh">{newer.title_zh}</span>
              <span class="nav-title-en">{newer.title_en}</span>
            </a>
          ) : <span class="nav-link nav-next nav-empty" aria-hidden="true"></span>}
        </nav>
      )}
    </div>
  </article>

  <script>
    (() => {
      const article = document.querySelector("article.article");
      const bar = document.querySelector<HTMLElement>(".reading-progress-bar");
      if (!article || !bar) return;

      const update = () => {
        const rect = article.getBoundingClientRect();
        const total = rect.height - window.innerHeight;
        const scrolled = -rect.top;
        const ratio = Math.max(0, Math.min(1, scrolled / Math.max(1, total)));
        bar.style.transform = `scaleX(${ratio})`;
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
    })();

    (() => {
      const links = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
      if (!links.length) return;

      const ids = Array.from(links).map((a) => a.dataset.target!);
      const headings = ids
        .map((id) => document.getElementById(id))
        .filter(Boolean) as HTMLElement[];
      if (!headings.length) return;

      let active = "";
      const mark = (id: string) => {
        if (id === active) return;
        active = id;
        links.forEach((a) =>
          a.classList.toggle("is-active", a.dataset.target === id),
        );
      };

      const onScroll = () => {
        const offset = 100;
        let current = headings[0]?.id ?? "";
        for (const h of headings) {
          if (h.getBoundingClientRect().top < offset) current = h.id;
          else break;
        }
        mark(current);
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      links.forEach((a) =>
        a.addEventListener("click", (e) => {
          e.preventDefault();
          const el = document.getElementById(a.dataset.target!);
          el?.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", `#${a.dataset.target}`);
        }),
      );
    })();
  </script>
</Base>

<style>
  /* ── reading progress ── */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    z-index: 20;
    pointer-events: none;
  }
  .reading-progress-bar {
    height: 100%;
    background: var(--accent-front);
    transform-origin: 0 50%;
    transform: scaleX(0);
    transition: transform 0.05s linear;
  }

  .article { padding: var(--sp-44) 0 var(--sp-96); position: relative; }

  /* ── TABLE OF CONTENTS ── */
  .toc { display: none; }
  @media (min-width: 1200px) {
    .toc {
      display: block;
      position: absolute;
      left: calc(50% + 35ch);
      top: 0;
      width: 190px;
    }
    .toc-inner {
      position: sticky;
      top: 80px;
      max-height: calc(100vh - 120px);
      overflow-y: auto;
      scrollbar-width: none;
    }
    .toc-inner::-webkit-scrollbar { display: none; }
    .toc-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-3);
      display: block;
      margin-bottom: var(--sp-12);
    }
    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      border-left: var(--sp-hairline) solid var(--rule);
    }
    .toc-item { margin: 0; }
    .toc-h3 { padding-left: var(--sp-12); }
    .toc-link {
      display: block;
      padding: var(--sp-4) 0 var(--sp-4) var(--sp-14);
      font-family: var(--sans);
      font-size: 12px;
      line-height: 1.4;
      color: var(--ink-3);
      border-left: 2px solid transparent;
      margin-left: -1px;
      transition: color 0.15s, border-color 0.15s;
    }
    .toc-link:hover { color: var(--ink); }
    .toc-link.is-active {
      color: var(--accent-front-ink);
      border-left-color: var(--accent-front);
    }
    .toc-divider {
      padding: var(--sp-8) 0 var(--sp-8) var(--sp-14);
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent-back);
      letter-spacing: 0.14em;
      list-style: none;
    }
  }

  /* 单语模式下隐藏翻面分隔 + 对应 TOC 条目 */
  :global(html.show-zh) .article-flip,
  :global(html.show-en) .article-flip { display: none; }
  :global(html.show-zh) .toc-item[data-lang="en"],
  :global(html.show-zh) .toc-divider,
  :global(html.show-en) .toc-item[data-lang="zh"],
  :global(html.show-en) .toc-divider { display: none; }

  /* heading 跳转偏移（补偿 sticky masthead） */
  .prose :global(h2[id]),
  .prose :global(h3[id]) { scroll-margin-top: 80px; }

  /* ─── HEAD ─── */
  .article-head {
    border-bottom: var(--sp-hairline) solid var(--rule);
    padding-bottom: var(--sp-32);
    margin: 0 auto var(--sp-44);
    max-width: 64ch;
  }
  .article-meta {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--sp-22);
    display: flex;
    gap: var(--sp-10);
    flex-wrap: wrap;
  }
  .article-meta .tags { color: var(--accent-back); }
  .article-title {
    font-family: var(--cjk-serif);
    font-size: clamp(var(--fs-6xl), 4.4vw, 56px);
    line-height: 1.08;
    margin: 0 0 var(--sp-12);
    color: var(--accent-front-ink);
    font-weight: var(--fw-medium);
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 56;
  }
  .article-title-en {
    font-family: var(--serif);
    font-size: var(--fs-3xl);
    line-height: 1.22;
    color: var(--accent-back-ink);
    font-style: italic;
    font-weight: var(--fw-light);
    margin: 0 0 var(--sp-22);
    letter-spacing: -0.01em;
  }
  .article-lede {
    font-family: var(--cjk-serif);
    font-size: var(--fs-xl);
    line-height: var(--lh-prose);
    color: var(--ink-2);
    margin: 0 0 var(--sp-10);
    font-weight: var(--fw-light);
  }
  .article-lede-en {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    color: var(--ink-3);
    margin: 0;
    font-weight: var(--fw-light);
  }

  /* ─── BODY ─── */
  .article-body { max-width: 64ch; margin: 0 auto; }

  .article-flip {
    max-width: 64ch;
    margin: var(--sp-72) auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--sp-18);
  }
  .flip-rule {
    height: var(--sp-hairline);
    background: var(--rule);
  }
  .flip-text {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.16em;
    color: var(--accent-back);
    white-space: nowrap;
  }

  /* ─── PROSE TYPOGRAPHY ─── */
  .prose {
    font-family: var(--serif);
    font-size: var(--fs-lg);
    line-height: var(--lh-prose);
    color: var(--ink);
  }
  .prose.cjk { font-family: var(--cjk-serif); }

  .prose :global(h2) {
    font-family: var(--serif);
    font-size: var(--fs-3xl);
    margin: var(--sp-44) 0 var(--sp-18);
    color: var(--ink);
    font-weight: var(--fw-medium);
    letter-spacing: -0.01em;
    line-height: 1.18;
  }
  .prose.cjk :global(h2) {
    font-family: var(--cjk-serif);
    color: var(--accent-front-ink);
  }
  .prose :global(h2:first-of-type) { margin-top: 0; }

  .prose :global(p) { margin: 0 0 var(--sp-18); }
  .prose :global(strong) { color: var(--ink); font-weight: var(--fw-medium); }

  .prose :global(em) {
    font-style: italic;
    color: var(--accent-back-ink);
    font-weight: var(--fw-light);
  }
  /* CJK em：dotted underline 不用 italic（CLAUDE.md 不变量 7） */
  .prose.cjk :global(em) {
    font-style: normal;
    color: inherit;
    text-decoration: underline;
    text-decoration-style: var(--cjk-em-line);
    text-decoration-color: var(--accent-front);
    text-decoration-thickness: var(--cjk-em-thickness);
    text-underline-offset: var(--cjk-em-offset);
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--sp-22);
    margin: 0 0 var(--sp-18);
  }
  .prose :global(li) { margin: 0 0 var(--sp-8); }

  .prose :global(hr) {
    border: none;
    border-top: var(--sp-hairline) solid var(--rule);
    margin: var(--sp-32) 0;
  }

  .prose :global(a) {
    color: var(--accent-front-ink);
    border-bottom: var(--sp-hairline) solid var(--accent-front);
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent-back);
    padding-left: var(--sp-18);
    color: var(--ink-2);
    font-style: italic;
    margin: var(--sp-22) 0;
  }
  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.92em;
    background: color-mix(in oklch, var(--ink) 5%, var(--paper));
    padding: 0.1em 0.4em;
    border-radius: 3px;
  }

  /* ─── PREV / NEXT NAV ─── */
  .article-nav {
    margin: var(--sp-96) auto 0;
    padding-top: var(--sp-32);
    border-top: var(--sp-hairline) solid var(--rule);
    max-width: 64ch;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-32);
  }
  .nav-link {
    display: grid;
    grid-template-columns: max-content 1fr;
    grid-template-rows: auto auto auto;
    grid-template-areas:
      "arrow label"
      "ztitle ztitle"
      "etitle etitle";
    gap: var(--sp-4) var(--sp-10);
    padding: var(--sp-18) 0;
    color: var(--ink);
    transition: color var(--dur-quick), transform var(--dur-quick);
  }
  .nav-prev { text-align: left; }
  .nav-next { text-align: right; grid-column: 2; }
  .nav-next .nav-arrow,
  .nav-next .nav-label { justify-self: end; }
  .nav-next {
    grid-template-areas:
      "label arrow"
      "ztitle ztitle"
      "etitle etitle";
    grid-template-columns: 1fr max-content;
  }
  .nav-empty { visibility: hidden; }

  .nav-arrow {
    grid-area: arrow;
    font-family: var(--serif);
    font-size: var(--fs-xl);
    color: var(--accent-back);
    line-height: 1;
  }
  .nav-label {
    grid-area: label;
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .nav-title-zh {
    grid-area: ztitle;
    font-family: var(--cjk-serif);
    font-size: var(--fs-xl);
    color: var(--ink);
    font-weight: var(--fw-medium);
    line-height: 1.3;
  }
  .nav-title-en {
    grid-area: etitle;
    font-family: var(--serif);
    font-size: var(--fs-md);
    color: var(--ink-3);
    font-style: italic;
    line-height: 1.3;
  }
  .nav-link:hover { color: var(--accent-front-ink); }
  .nav-link:hover .nav-arrow { color: var(--accent-front); }
  .nav-prev:hover .nav-arrow { transform: translateX(-3px); }
  .nav-next:hover .nav-arrow { transform: translateX(3px); }

  @media (max-width: 720px) {
    .article-nav { grid-template-columns: 1fr; }
    .nav-next, .nav-prev { grid-column: 1; }
  }
</style>
