---
/*
 * ⊙ CoinGlyph — conilab 的核心 motif
 * 同心双圆，可加内点/斜线变体。替代 lixiaolai 的 § 段落符。
 *
 * 用在：kicker 前缀 / chapter-num / colophon-card 印章 / footer h4 等
 */
interface Props {
  size?: number | string;     // em 单位最佳，默认 1em
  variant?: "ring" | "dot" | "slash" | "stamp";
  color?: string;             // 默认 currentColor
  strokeWidth?: number;
}
const {
  size = "1em",
  variant = "ring",
  color = "currentColor",
  strokeWidth = 0.9,
} = Astro.props;

const sz = typeof size === "number" ? `${size}px` : size;
---

<svg
  class={`coin-glyph coin-glyph--${variant}`}
  viewBox="0 0 24 24"
  width={sz}
  height={sz}
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  aria-hidden="true"
  focusable="false"
>
  <circle cx="12" cy="12" r="10" />
  <circle cx="12" cy="12" r="6.5" stroke-width={strokeWidth * 0.7} />
  {variant === "dot"   && <circle cx="12" cy="12" r="1.6" fill={color} stroke="none" />}
  {variant === "slash" && <line x1="7.5" y1="16.5" x2="16.5" y2="7.5" />}
  {variant === "stamp" && (
    <>
      <circle cx="12" cy="12" r="1.6" fill={color} stroke="none" />
      <line x1="7.5" y1="16.5" x2="16.5" y2="7.5" />
    </>
  )}
</svg>

<style is:global>
  /* baseline：所有 coin-glyph 都有翻转过渡 */
  .coin-glyph {
    display: inline-block;
    vertical-align: -0.12em;
    flex: none;
    transform-style: preserve-3d;
    transition: transform 800ms cubic-bezier(0.4, 0.05, 0.2, 1);
    will-change: transform;
  }

  /* —— 父元素 hover 时硬币翻面（"两面"主题强化）—— */
  .hero-rubric:hover .coin-glyph,
  .hero-divider:hover .coin-glyph,
  .chapter-head:hover .coin-glyph,
  .footer-mark:hover .coin-glyph,
  .footer h4:hover .coin-glyph,
  .kicker:hover .coin-glyph {
    transform: rotateY(360deg);
  }

  /* 持续微动：让 hero-divider 中央 ⊙ 在静止时有"硬币缓慢转向你"的呼吸感 */
  @keyframes coin-breath {
    0%, 100% { transform: rotateY(0deg); }
    50%      { transform: rotateY(180deg); }
  }
  .hero-divider .coin-glyph {
    animation: coin-breath 12s ease-in-out infinite;
  }
  /* hover 时让用户接管：覆盖呼吸动画 */
  .hero-divider:hover .coin-glyph {
    animation: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .coin-glyph,
    .hero-divider .coin-glyph {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
