---
/*
 * Kicker — 小标题
 * 招式：mono uppercase 0.10~0.14em tracking + ink-3 灰 / 可切 accent-front
 * 默认前置 ⊙ 同心双圆（CoinGlyph）替代 lixiaolai 的 § 段落符
 */
import CoinGlyph from "./CoinGlyph.astro";

interface Props {
  text: string;
  accent?: boolean;
  /** 是否在前置 ⊙ glyph，默认 true。设 false 时纯文字 kicker */
  glyph?: boolean;
  as?: "div" | "span";
}
const { text, accent = false, glyph = true, as = "div" } = Astro.props;
const Tag = as as any;
---

<Tag class={`kicker ${accent ? "kicker--accent" : ""}`}>
  {glyph && <CoinGlyph variant="ring" />}
  <span>{text}</span>
</Tag>

<style>
  .kicker {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: var(--fw-normal);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-8);
  }
  .kicker--accent {
    color: var(--accent-front);
    letter-spacing: 0.14em;
  }
</style>
