---
/*
 * ChapterHead — 章节头
 *   ─── ⊙ Ⅰ · ARTICLES
 *   The journal — <em>a commonplace book</em>
 *
 * 替代 lixiaolai 的 "§ 01 · ARTICLES" 招式：
 *   - § → ⊙（CoinGlyph，conilab signature）
 *   - 阿拉伯数字 01 → 罗马数字 Ⅰ Ⅱ Ⅲ（实验记录簿味道，配合 "lab" 字面）
 *   - bar 用 accent-front 默认；side="back" 时切到暖铜 accent-back
 *
 * num 接受任意字符串，建议用 Roman: I / II / III / IV / V
 */
import CoinGlyph from "./CoinGlyph.astro";

interface Props {
  num: string;             // "I" / "II" / "III"
  label: string;           // "ARTICLES"
  allHref?: string;
  allLabel?: string;
  side?: "front" | "back"; // 决定 bar / num 颜色，对应硬币正反面
}
const {
  num,
  label,
  allHref,
  allLabel = "All",
  side = "front",
} = Astro.props;
---

<div class={`chapter-head chapter-head--${side}`}>
  <div class="chapter-num">
    <span class="bar" aria-hidden="true"></span>
    <CoinGlyph variant="ring" />
    <span class="num">{num}</span>
    <span class="dot" aria-hidden="true">·</span>
    <span class="label">{label}</span>
  </div>
  <h2 class="chapter-title">
    <slot />
  </h2>
  {allHref && (
    <a class="all-link" href={allHref}>{allLabel} <span aria-hidden="true">→</span></a>
  )}
</div>

<style>
  .chapter-head {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "num all"
      "title all";
    column-gap: var(--sp-24);
    row-gap: var(--sp-10);
    align-items: end;
    padding: var(--sp-48) 0 var(--sp-26);
    border-bottom: var(--sp-hairline) solid var(--rule);
    margin-bottom: var(--sp-32);
  }
  .chapter-num {
    grid-area: num;
    font-family: var(--mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: var(--sp-8);
  }
  .chapter-num .bar {
    width: var(--sp-40);
    height: var(--sp-hairline);
  }
  .chapter-num .num {
    font-family: var(--serif);
    font-style: italic;
    font-weight: var(--fw-light);
    font-size: var(--fs-md);
    letter-spacing: 0;
  }
  .chapter-num .dot { opacity: 0.5; }
  .chapter-num .label { letter-spacing: 0.14em; }

  .chapter-head--front .chapter-num,
  .chapter-head--front .chapter-num .bar {
    color: var(--accent-front);
    background: var(--accent-front);
  }
  .chapter-head--front .chapter-num,
  .chapter-head--front .chapter-num .num,
  .chapter-head--front .chapter-num .label,
  .chapter-head--front .chapter-num .dot { background: transparent; }
  .chapter-head--front .chapter-num { color: var(--accent-front); }
  .chapter-head--front .chapter-num .bar { background: var(--accent-front); }

  .chapter-head--back .chapter-num { color: var(--accent-back); }
  .chapter-head--back .chapter-num .bar { background: var(--accent-back); }

  .chapter-title {
    grid-area: title;
    font-family: var(--serif);
    font-weight: var(--fw-normal);
    font-size: var(--fs-7xl);
    letter-spacing: -0.015em;
    line-height: var(--lh-title-loose);
    margin: 0;
  }
  .chapter-title :global(em) {
    font-style: italic;
    font-weight: var(--fw-light);
    color: var(--ink-2);
  }
  .all-link {
    grid-area: all;
    font-family: var(--mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    align-self: end;
    padding-bottom: var(--sp-6);
    border-bottom: var(--sp-hairline) solid transparent;
    transition: color var(--dur-quick), border-color var(--dur-quick);
  }
  .all-link:hover {
    color: var(--accent-front-ink);
    border-bottom-color: var(--accent-front);
  }
  @media (max-width: 720px) {
    .chapter-title { font-size: var(--fs-5xl); }
  }
</style>
