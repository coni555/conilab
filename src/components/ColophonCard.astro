---
/*
 * ColophonCard — 试验登记卡（conilab 版）
 *   - 1px hairline 描边 + paper-2 底
 *   - :before 浮 "⊙ LABNOTE / 试验登记" 小邮票（替代 lixiaolai 的 § DISPATCH · COLOPHON）
 *   - 三段：head（双面铭牌）/ rule（中间 ⊙ 分隔）/ body（co-line × N）
 *   - 右下角 ⊙ 印章 SVG（半透明，"已登记"语义）
 */
import CoinGlyph from "./CoinGlyph.astro";
interface Entry {
  label: string;
  value: string;
  accent?: boolean;
  href?: string;
}
interface Props {
  bureau?: string;        // 显示在铭牌"BUREAUX"下
  bureauList?: string[];
  entries: Entry[];
  stamp?: string;         // 顶部浮签默认 "§ DISPATCH · COLOPHON"
}
const {
  bureau = "Online",
  bureauList = ["Online"],
  entries,
  stamp = "⊙ LABNOTE · 试验登记",
} = Astro.props;
---

<aside class="colophon-card" aria-label="Dispatch and colophon" data-stamp={stamp}>
  <div class="co-head">
    <div class="co-poster" aria-hidden="true">
      <!-- 双面 motif：左右两枚同心圆，象征硬币正反 / 中英 / 阅读·写作 -->
      <svg viewBox="0 0 80 80" aria-hidden="true">
        <g transform="translate(20 40)">
          <circle r="14" fill="none" stroke="var(--accent-front)" stroke-width="1" />
          <circle r="9"  fill="none" stroke="var(--accent-front)" stroke-width="0.6" />
          <text y="3" text-anchor="middle" font-family="var(--serif)" font-size="9" font-style="italic" fill="var(--accent-front)">中</text>
        </g>
        <g transform="translate(60 40)">
          <circle r="14" fill="none" stroke="var(--accent-back)" stroke-width="1" />
          <circle r="9"  fill="none" stroke="var(--accent-back)" stroke-width="0.6" />
          <text y="3" text-anchor="middle" font-family="var(--serif)" font-size="9" font-style="italic" fill="var(--accent-back)">en</text>
        </g>
        <line x1="34" y1="40" x2="46" y2="40" stroke="var(--ink-3)" stroke-width="0.5" />
      </svg>
    </div>
    <dl class="co-dl">
      <dt class="co-dl-k">REGISTRY</dt>
      <dd class="co-dl-v">
        <strong>{bureau}</strong>
        {bureauList.length > 1 && (
          <span class="co-dl-list">
            {bureauList.filter((b) => b !== bureau).map((b) => <span>· {b}</span>)}
          </span>
        )}
      </dd>
    </dl>
  </div>

  <div class="co-rule" aria-hidden="true">
    <span class="co-rule-glyph">
      <CoinGlyph variant="dot" />
    </span>
  </div>

  <div class="co-body">
    {entries.map((e) => (
      <div class="co-line">
        <span class="k" aria-hidden="true">•</span>
        <span class="l">{e.label}</span>
        <span class={`v ${e.accent ? "accent" : ""}`}>
          {e.href ? <a href={e.href}>{e.value}</a> : e.value}
        </span>
      </div>
    ))}
  </div>

  <!-- 右下角 ⊙ 印章 SVG（已登记语义，半透明）-->
  <span class="co-stamp" aria-hidden="true">
    <CoinGlyph variant="stamp" size="3.2em" strokeWidth={0.6} />
  </span>
</aside>

<style>
  .colophon-card {
    border: var(--sp-hairline) solid var(--rule);
    background: var(--paper-2);
    padding: var(--sp-36) var(--sp-32) var(--sp-26);
    font-family: var(--mono);
    color: var(--ink);
    position: relative;
    display: grid;
    gap: var(--sp-20);
    align-self: stretch;
    min-height: 100%;
  }
  .colophon-card::before {
    content: attr(data-stamp);
    position: absolute;
    top: calc(var(--sp-9) * -1);
    left: var(--sp-22);
    background: var(--paper);
    padding: 0 var(--sp-10);
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.16em;
    color: var(--accent-front);
  }
  .co-stamp {
    position: absolute;
    right: var(--sp-18);
    bottom: var(--sp-14);
    color: var(--accent-back);
    opacity: 0.28;
    pointer-events: none;
    transform: rotate(-8deg);
    transition: opacity var(--dur-normal), transform var(--dur-normal);
  }
  .colophon-card:hover .co-stamp {
    opacity: 0.45;
    transform: rotate(-6deg) scale(1.05);
  }

  .co-head {
    display: grid;
    grid-template-columns: var(--sp-72) 1fr;
    gap: var(--sp-18);
    align-items: center;
    padding-bottom: var(--sp-4);
  }
  .co-poster {
    width: var(--sp-72);
    height: var(--sp-72);
    color: var(--ink-3);
  }
  .co-poster svg { width: 100%; height: 100%; }

  .co-dl { margin: 0; }
  .co-dl-k {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--sp-4);
  }
  .co-dl-v {
    margin: 0;
    font-family: var(--mono);
    font-size: var(--fs-md);
    color: var(--ink);
  }
  .co-dl-v strong { font-weight: var(--fw-medium); }
  .co-dl-list {
    color: var(--ink-3);
    margin-left: var(--sp-6);
  }
  .co-dl-list span { margin-right: var(--sp-4); }

  .co-rule {
    position: relative;
    height: var(--sp-hairline);
    background: var(--rule);
    margin: 0;
  }
  .co-rule span {
    position: absolute;
    left: 50%;
    top: calc(var(--sp-10) * -1);
    transform: translateX(-50%);
    background: var(--paper-2);
    padding: 0 var(--sp-12);
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-base);
    color: var(--ink-3);
  }

  .co-body { display: grid; gap: var(--sp-2); }
  .co-line {
    display: grid;
    grid-template-columns: var(--sp-20) var(--sp-72) 1fr;
    gap: var(--sp-12);
    align-items: baseline;
    padding: var(--sp-6) 0;
    border-bottom: var(--sp-hairline) dashed var(--rule-soft);
  }
  .co-line:last-child { border-bottom: none; }
  .co-line .k {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    color: var(--accent-front);
    font-weight: var(--fw-medium);
  }
  .co-line .l {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .co-line .v {
    font-family: var(--mono);
    font-size: var(--fs-md);
    color: var(--ink);
  }
  .co-line .v.accent { color: var(--accent-front-ink); }
  .co-line .v a {
    border-bottom: var(--sp-hairline) solid transparent;
    transition: border-color var(--dur-quick), color var(--dur-quick);
  }
  .co-line .v a:hover {
    color: var(--accent-front-ink);
    border-bottom-color: var(--accent-front);
  }
</style>
