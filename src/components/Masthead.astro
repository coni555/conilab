---
import Mark from "./Mark.astro";

interface Props {
  /** 当前日期，DD.MM.YYYY 欧式 */
  today?: string;
}

const today =
  Astro.props.today ??
  new Intl.DateTimeFormat("en-GB", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
  })
    .format(new Date())
    .replaceAll("/", ".");

const primaryNav = [
  { href: "/articles", label: "Articles" },
  { href: "/notes", label: "Notes" },
];

const moreNav = [
  { href: "/books", label: "Books" },
  { href: "/milestones", label: "Milestones" },
  { href: "/works", label: "Works" },
  { href: "/interests", label: "Interests" },
];

const metaNav = [
  { href: "/about", label: "About" },
  { href: "/join", label: "Join", cta: true },
];

const pathname = Astro.url.pathname;
const moreIsActive = moreNav.some((it) => pathname.startsWith(it.href));
---

<header class="masthead">
  <div class="wrap masthead-row">
    <Mark>
      <span slot="handle" class="handle">@coni — {today}</span>
    </Mark>

    <nav class="primary" aria-label="Primary">
      <ul>
        {primaryNav.map((it) => (
          <li>
            <a
              href={it.href}
              {...(pathname.startsWith(it.href) ? {"aria-current": "page"} : {})}
            >{it.label}</a>
          </li>
        ))}
        <li class="nav-more">
          <button
            class={`more-trigger ${moreIsActive ? "is-active" : ""}`}
            aria-expanded="false"
            aria-haspopup="true"
          >More <span class="more-caret" aria-hidden="true">▾</span></button>
          <ul class="more-dropdown">
            {moreNav.map((it) => (
              <li>
                <a
                  href={it.href}
                  {...(pathname.startsWith(it.href) ? {"aria-current": "page"} : {})}
                >{it.label}</a>
              </li>
            ))}
          </ul>
        </li>
      </ul>
    </nav>

    <nav class="meta" aria-label="Meta">
      <ul>
        {metaNav.map((it) => (
          <li class={it.cta ? "nav-cta" : undefined}>
            <a
              href={it.href}
              {...(pathname.startsWith(it.href) ? {"aria-current": "page"} : {})}
            >{it.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="utility">
      <div class="lang-switcher" role="group" aria-label="Language">
        <button data-lang="both" class="lang-btn">中 / EN</button>
        <button data-lang="zh"   class="lang-btn">中</button>
        <button data-lang="en"   class="lang-btn is-active" aria-pressed="true">EN</button>
      </div>

      <button
        type="button"
        class="theme-toggle"
        aria-label="Toggle dark mode"
        aria-pressed="false"
        title="Flip to the other side"
      >
        <span class="theme-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="9" />
            <circle cx="12" cy="12" r="4" />
            <path d="M12 3 L12 21" stroke-dasharray="2 3" />
          </svg>
        </span>
        <span class="theme-label">DAY</span>
      </button>
    </div>
  </div>
</header>

<script>
  // ── More dropdown
  const moreTrigger = document.querySelector<HTMLButtonElement>(".more-trigger");
  const moreDropdown = document.querySelector<HTMLUListElement>(".more-dropdown");
  if (moreTrigger && moreDropdown) {
    moreTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = moreTrigger.getAttribute("aria-expanded") === "true";
      moreTrigger.setAttribute("aria-expanded", String(!open));
      moreDropdown.classList.toggle("is-open", !open);
    });
    document.addEventListener("click", () => {
      moreTrigger.setAttribute("aria-expanded", "false");
      moreDropdown.classList.remove("is-open");
    });
    moreDropdown.addEventListener("click", (e) => e.stopPropagation());
  }

  // ── Lang switcher
  const root = document.documentElement;
  const btns = document.querySelectorAll<HTMLButtonElement>(".lang-btn");
  const apply = (mode: string) => {
    root.classList.remove("show-zh", "show-en");
    if (mode === "zh") root.classList.add("show-zh");
    if (mode === "en") root.classList.add("show-en");
    btns.forEach((b) => {
      const on = b.dataset.lang === mode;
      b.classList.toggle("is-active", on);
      b.setAttribute("aria-pressed", String(on));
    });
    try { localStorage.setItem("conilab-lang", mode); } catch {}
  };
  btns.forEach((b) =>
    b.addEventListener("click", () => apply(b.dataset.lang || "both"))
  );
  try {
    const saved = localStorage.getItem("conilab-lang");
    apply(saved || "en");
  } catch {
    apply("en");
  }

  // ── Theme toggle
  const themeBtn = document.querySelector<HTMLButtonElement>(".theme-toggle");
  const themeLabel = themeBtn?.querySelector<HTMLSpanElement>(".theme-label");
  const syncTheme = () => {
    const isDark = root.classList.contains("dark");
    themeBtn?.setAttribute("aria-pressed", String(isDark));
    if (themeLabel) themeLabel.textContent = isDark ? "NIGHT" : "DAY";
  };
  syncTheme();
  themeBtn?.addEventListener("click", () => {
    root.classList.toggle("dark");
    syncTheme();
    try { localStorage.setItem("conilab-theme", root.classList.contains("dark") ? "dark" : "light"); } catch {}
  });
  try {
    const mq = window.matchMedia("(prefers-color-scheme: dark)");
    mq.addEventListener("change", (e) => {
      if (localStorage.getItem("conilab-theme")) return;
      root.classList.toggle("dark", e.matches);
      syncTheme();
    });
  } catch {}
</script>

<style>
  .masthead {
    border-bottom: var(--sp-hairline) solid var(--rule);
    padding: var(--sp-16) 0 var(--sp-14);
    position: sticky;
    top: 0;
    background: color-mix(in oklch, var(--paper) 92%, transparent);
    -webkit-backdrop-filter: blur(var(--sp-10));
    backdrop-filter: blur(var(--sp-10));
    z-index: 10;
  }
  .masthead-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sp-24);
  }

  .handle {
    font-family: var(--mono);
    font-size: var(--fs-sm);
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-left: var(--sp-12);
    border-left: var(--sp-hairline) solid var(--rule);
    margin-left: var(--sp-6);
    align-self: center;
  }

  /* ── Primary nav ── */
  nav.primary ul {
    display: flex;
    gap: var(--sp-28);
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--sans);
    font-size: var(--fs-md);
  }
  nav.primary a {
    color: var(--ink-2);
    border-bottom: var(--sp-hairline) solid transparent;
    padding-bottom: var(--sp-2);
    transition: color var(--dur-quick), border-color var(--dur-quick);
  }
  nav.primary a:hover,
  nav.primary a[aria-current="page"] {
    color: var(--accent-deep-ink);
    border-bottom-color: var(--accent-deep);
  }

  /* ── More dropdown ── */
  .nav-more {
    position: relative;
  }
  .more-trigger {
    font-family: var(--sans);
    font-size: var(--fs-md);
    color: var(--ink-2);
    background: none;
    border: none;
    border-bottom: var(--sp-hairline) solid transparent;
    padding: 0 0 var(--sp-2);
    cursor: pointer;
    transition: color var(--dur-quick), border-color var(--dur-quick);
  }
  .more-trigger:hover,
  .more-trigger.is-active {
    color: var(--accent-deep-ink);
    border-bottom-color: var(--accent-deep);
  }
  .more-caret {
    font-size: 0.75em;
    opacity: 0.5;
    transition: transform var(--dur-quick);
  }
  .more-trigger[aria-expanded="true"] .more-caret {
    transform: rotate(180deg);
  }

  nav.primary .more-dropdown {
    display: none !important;
    position: absolute;
    top: calc(100% + var(--sp-10));
    left: 50%;
    transform: translateX(-50%);
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: var(--sp-8) 0;
    background: var(--paper);
    border: var(--sp-hairline) solid var(--rule);
    min-width: 160px;
    z-index: 20;
    font-family: var(--sans);
    font-size: var(--fs-md);
  }
  nav.primary .more-dropdown.is-open {
    display: flex !important;
  }
  nav.primary .more-dropdown li {
    padding: 0;
  }
  nav.primary .more-dropdown a {
    display: block;
    padding: var(--sp-8) var(--sp-18);
    color: var(--ink-2);
    border-bottom: none;
    transition: color var(--dur-quick), background-color var(--dur-quick);
  }
  nav.primary .more-dropdown a:hover {
    color: var(--accent-deep-ink);
    background: color-mix(in oklch, var(--accent-front) 5%, var(--paper));
  }
  nav.primary .more-dropdown a[aria-current="page"] {
    color: var(--accent-deep-ink);
  }

  /* ── Meta nav (About + Join) ── */
  nav.meta {
    margin-left: auto;
    border-left: var(--sp-hairline) solid var(--rule);
    padding-left: var(--sp-22);
  }
  nav.meta ul {
    display: flex;
    gap: var(--sp-22);
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--sans);
    font-size: var(--fs-md);
  }
  nav.meta a {
    color: var(--ink-2);
    border-bottom: var(--sp-hairline) solid transparent;
    padding-bottom: var(--sp-2);
    transition: color var(--dur-quick), border-color var(--dur-quick);
  }
  nav.meta a:hover,
  nav.meta a[aria-current="page"] {
    color: var(--accent-deep-ink);
    border-bottom-color: var(--accent-deep);
  }
  nav.meta .nav-cta a {
    color: var(--accent-back-ink);
    padding-left: var(--sp-12);
    position: relative;
  }
  nav.meta .nav-cta a::before {
    content: "⊙";
    position: absolute;
    left: 0;
    color: var(--accent-back);
    font-size: 0.85em;
    line-height: inherit;
  }
  nav.meta .nav-cta a:hover,
  nav.meta .nav-cta a[aria-current="page"] {
    color: var(--accent-back);
    border-bottom-color: var(--accent-back);
  }

  /* ── Utility ── */
  .utility {
    display: flex;
    align-items: center;
    gap: var(--sp-10);
  }
  .lang-switcher {
    display: flex;
    gap: var(--sp-4);
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.1em;
  }
  .lang-btn {
    border: var(--sp-hairline) solid var(--rule);
    background: transparent;
    color: var(--ink-3);
    padding: var(--sp-4) var(--sp-10);
    border-radius: var(--rad-pill);
    cursor: pointer;
    text-transform: uppercase;
    transition: color var(--dur-quick), background-color var(--dur-quick), border-color var(--dur-quick);
  }
  .lang-btn:hover { border-color: var(--ink-3); color: var(--ink); }
  .lang-btn.is-active {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-6);
    border: var(--sp-hairline) solid var(--rule);
    background: transparent;
    color: var(--ink-3);
    padding: var(--sp-4) var(--sp-10);
    border-radius: var(--rad-pill);
    cursor: pointer;
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color var(--dur-quick), background-color var(--dur-quick), border-color var(--dur-quick);
    padding-left: var(--sp-8);
  }
  .theme-toggle:hover {
    border-color: var(--ink-3);
    color: var(--ink);
  }
  .theme-icon {
    display: inline-flex;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .theme-toggle:hover .theme-icon {
    transform: rotateY(180deg);
  }
  :global(html.dark) .theme-icon {
    transform: rotateY(180deg);
    color: var(--accent-back);
  }
  :global(html.dark) .theme-toggle {
    border-color: color-mix(in oklch, var(--accent-back) 35%, var(--rule));
  }
  @media (prefers-reduced-motion: reduce) {
    .theme-icon,
    .theme-toggle:hover .theme-icon,
    :global(html.dark) .theme-icon { transition: none; transform: none; }
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .masthead-row { flex-wrap: wrap; gap: var(--sp-10); }
    nav.primary { order: 3; flex-basis: 100%; }
    nav.primary ul {
      gap: var(--sp-14) var(--sp-18);
      justify-content: flex-start;
      flex-wrap: wrap;
    }
    nav.meta {
      order: 4;
      flex-basis: 100%;
      border-left: none;
      padding-left: 0;
    }
    nav.meta ul {
      gap: var(--sp-14) var(--sp-18);
    }
    .theme-label { display: none; }
    .theme-toggle { padding: var(--sp-4) var(--sp-8); }
  }
</style>
