---
import CoinGlyph from "./CoinGlyph.astro";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div class="footer-mark">
          <CoinGlyph variant="dot" size="0.9em" />
          <span>conilab</span>
          <em>·</em>
        </div>
      </div>
      <div>
        <h4><CoinGlyph variant="ring" />Read</h4>
        <ul>
          <li><a href="/articles">Articles</a></li>
          <li><a href="/notes">Notes</a></li>
          <li><a href="/articles/rss.xml">RSS</a></li>
        </ul>
      </div>
      <div>
        <h4><CoinGlyph variant="ring" />Elsewhere</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="https://github.com/coni555" rel="me">GitHub</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} conilab</span>
      <span>conilab.cn — a notebook with two faces</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-96);
    padding: var(--sp-64) 0 var(--sp-44);
    border-top: var(--sp-hairline) solid var(--rule);
    background: var(--paper);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--sp-44);
    margin-bottom: var(--sp-44);
  }
  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr; gap: var(--sp-28); }
  }
  .footer-mark {
    font-family: var(--serif);
    font-size: var(--fs-3xl);
    color: var(--ink);
    font-weight: var(--fw-medium);
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-12);
    display: inline-flex;
    align-items: baseline;
    gap: var(--sp-8);
  }
  .footer-mark :global(.coin-glyph) {
    color: var(--accent-front);
    align-self: center;
  }
  .footer-mark em {
    font-style: italic;
    font-weight: var(--fw-light);
    color: var(--accent-back);
  }
  .footer-blurb {
    font-family: var(--serif);
    font-size: var(--fs-md);
    color: var(--ink-2);
    line-height: var(--lh-relaxed);
    max-width: 52ch;
    margin: 0;
  }
  .footer-blurb em {
    font-style: italic;
    color: var(--accent-front-ink);
    font-weight: var(--fw-light);
  }
  .footer h4 {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-front);
    margin: 0 0 var(--sp-12);
    font-weight: var(--fw-medium);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-6);
  }
  .footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-6);
    font-family: var(--mono);
    font-size: var(--fs-sm);
  }
  .footer a {
    color: var(--ink-2);
    border-bottom: var(--sp-hairline) solid transparent;
    transition: all var(--dur-quick);
  }
  .footer a:hover {
    color: var(--accent-front-ink);
    border-bottom-color: var(--accent-front);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--sp-20);
    padding-top: var(--sp-22);
    border-top: var(--sp-hairline) solid var(--rule);
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  @media (max-width: 720px) {
    .footer-bottom { flex-direction: column; gap: var(--sp-8); }
  }
</style>
