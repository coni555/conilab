---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div class="footer-mark">conilab<em>·</em></div>
        <p class="footer-blurb">
          Maintained by <strong>@coni</strong>. Long-form notes from a Chinese student
          re-learning the world with AI. Set in <em>Source Serif 4</em> and
          <em>Inter</em>. Built in the open.
        </p>
      </div>
      <div>
        <h4>Read</h4>
        <ul>
          <li><a href="/articles">Articles</a></li>
          <li><a href="/notes">Notes</a></li>
          <li><a href="/articles/rss.xml">RSS</a></li>
        </ul>
      </div>
      <div>
        <h4>Elsewhere</h4>
        <ul>
          <li><a href="https://github.com/coni555" rel="me">GitHub</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} @coni</span>
      <span>Shaoxing · written between Obsidian and the open web</span>
      <span><a href="https://beian.miit.gov.cn/" rel="noopener noreferrer" target="_blank">备案号待添加</a></span>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-96);
    padding: var(--sp-64) 0 var(--sp-44);
    border-top: var(--sp-hairline) solid var(--rule);
    background: var(--paper);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--sp-44);
    margin-bottom: var(--sp-44);
  }
  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr; gap: var(--sp-28); }
  }
  .footer-mark {
    font-family: var(--serif);
    font-size: var(--fs-3xl);
    color: var(--ink);
    font-weight: var(--fw-medium);
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-12);
  }
  .footer-mark em {
    font-style: italic;
    font-weight: var(--fw-light);
    color: var(--accent-deep);
  }
  .footer-blurb {
    font-family: var(--serif);
    font-size: var(--fs-md);
    color: var(--ink-2);
    line-height: var(--lh-relaxed);
    max-width: 52ch;
    margin: 0;
  }
  .footer-blurb em {
    font-style: italic;
    color: var(--accent-deep-ink);
    font-weight: var(--fw-light);
  }
  .footer h4 {
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin: 0 0 var(--sp-12);
    font-weight: var(--fw-medium);
  }
  .footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--sp-6);
    font-family: var(--mono);
    font-size: var(--fs-sm);
  }
  .footer a {
    color: var(--ink-2);
    border-bottom: var(--sp-hairline) solid transparent;
    transition: all var(--dur-quick);
  }
  .footer a:hover {
    color: var(--accent-deep-ink);
    border-bottom-color: var(--accent-deep);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--sp-20);
    padding-top: var(--sp-22);
    border-top: var(--sp-hairline) solid var(--rule);
    font-family: var(--mono);
    font-size: var(--fs-2xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  @media (max-width: 720px) {
    .footer-bottom { flex-direction: column; gap: var(--sp-8); }
  }
</style>
